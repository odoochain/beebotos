{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "schedule": [
    "before 5am on monday"
  ],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchPackagePatterns": ["^tokio"],
      "groupName": "tokio packages"
    },

    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ],
  "cargo": {
    "enabled": true
  }
}
