# BeeBotOS 敏感配置（不要提交到 Git）
# 前缀 BEE 与 config crate 的分隔符 __ 配合，对应 TOML 的层级结构
# 注意：变量名格式为 BEE__{SECTION}__{KEY}（BEE 后紧跟双下划线）

# JWT 签名密钥（至少 32 位字符）
BEE__JWT__SECRET=12s2dfHd8ksd0Lkd789gHjyIRT87XX0998dfDLL9hMGEss33Whlfk783jf00bfdhs3lkdKKL9

# Kimi 大模型 API 密钥
BEE__MODELS__KIMI__API_KEY=xxxx

# Zhipu 大模型 API 密钥
BEE__MODELS__ZHIPU__API_KEY=xxxx

# 飞书（Lark）应用密钥
BEE__CHANNELS__LARK__APP_SECRET=xxxx

# 企业微信 CorpSecret
BEE__CHANNELS__WECHAT__CORP_SECRET=xxxx
# 企业微信 Token
BEE__CHANNELS__WECHAT__TOKEN=xxxx
# 企业微信消息加解密密钥
BEE__CHANNELS__WECHAT__ENCODING_AES_KEY=xxxx
